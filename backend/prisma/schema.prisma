generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Operator {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  active    Boolean  @default(true)
  plans     Plan[]
  hospitals Hospital[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Plan {
  id                 String     @id @default(cuid())
  slug               String     @unique
  name               String
  registroANS        String
  tier               String
  room               String
  coverage           String
  hasReimbursement   Boolean    @default(false)
  reimbursementLevel String?
  hasCoparticipation Boolean    @default(false)
  segmentation       String
  highlights         String[]
  limitations        String[]
  active             Boolean    @default(true)
  operatorId         String
  operator           Operator   @relation(fields: [operatorId], references: [id])
  prices             PlanPrice[]
  leadPlans          LeadPlan[]
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  @@index([operatorId])
  @@index([tier])
  @@index([coverage])
}

model PlanPrice {
  id         String @id @default(cuid())
  planId     String
  plan       Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  personType String
  ageBand    String
  price      Float

  @@unique([planId, personType, ageBand])
  @@index([planId])
}

model Hospital {
  id         String   @id @default(cuid())
  name       String
  city       String
  emergency  Boolean  @default(false)
  type       String
  planCount  Int      @default(0)
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])

  @@index([city])
  @@index([operatorId])
}

enum LeadStatus {
  NEW
  CONTACTED
  NEGOTIATING
  CLOSED
  LOST
}

model Lead {
  id               String       @id @default(cuid())
  name             String
  phone            String
  email            String?
  city             String?
  status           LeadStatus   @default(NEW)
  notes            String?
  sessionId        String?
  conversationId   String?      @unique
  conversation     Conversation? @relation(fields: [conversationId], references: [id])
  leadPlans        LeadPlan[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([status])
  @@index([createdAt])
}

model LeadPlan {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  planId String
  plan   Plan   @relation(fields: [planId], references: [id])
  score  Float?

  @@unique([leadId, planId])
}

model Conversation {
  id        String   @id @default(cuid())
  sessionId String   @unique
  messages  Json
  profile   Json?
  lead      Lead?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Broker {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  susep     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
